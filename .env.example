# MongoDB — replica-set (individual parts; MONGO_URI takes precedence if set)
MONGO_HOSTS=rs1.sisx.in:27001,rs2.sisx.in:27001,rs3.sisx.in:27000
MONGO_REPLICA_SET=rssisx
MONGO_USER=viadmin
MONGO_PASSWORD=vi4eO#Ai
MONGO_AUTH_SOURCE=videoAnalyticDB
MONGO_DB=videoAnalyticDB

# Override the entire URI (optional — takes precedence over individual parts above)
# MONGO_URI=mongodb://user:pass@host1:port,host2:port/db?replicaSet=rs&authSource=db

# RTSP
RTSP_BASE_URL=rtsp://localhost:8554

# Inference
FPS_THROTTLE=5
CONFIDENCE_THRESHOLD=0.4
TORCH_NUM_THREADS=4
YOLO_MODEL=yolov8n.pt
FRAME_DOWNSCALE_WIDTH=640

# Event logic
COOLDOWN_SECONDS=30
TEMPORAL_CONFIRM_FRAMES=3
